{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ravo.dev/schemas/analysis-artifact.schema.json",
  "title": "RAVO Analysis Artifact",
  "type": "object",
  "required": ["schemaVersion", "id", "type", "status", "title", "createdAt", "derivedConclusion"],
  "properties": {
    "schemaVersion": {
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "type": {
      "enum": ["requirement", "root-cause", "solution"]
    },
    "status": {
      "enum": ["draft", "complete"]
    },
    "title": {
      "type": "string"
    },
    "goal": {
      "type": "string"
    },
    "constraints": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "facts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "challenge": {
      "type": "string"
    },
    "whyChain": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "alternativeHypotheses": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "rootCause": {
      "type": "object",
      "properties": {
        "symptom": {
          "type": "string"
        },
        "proximateCause": {
          "type": "string"
        },
        "mechanismRootCause": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "derivedConclusion": {
      "type": "string"
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "nextActions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true
  ,
  "allOf": [
    {
      "if": {
        "required": ["type", "status"],
        "properties": {
          "type": { "enum": ["requirement", "solution"] },
          "status": { "const": "complete" }
        }
      },
      "then": {
        "required": ["facts", "challenge", "derivedConclusion"],
        "properties": {
          "facts": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "challenge": {
            "type": "string",
            "minLength": 1
          },
          "derivedConclusion": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    {
      "if": {
        "required": ["type", "status"],
        "properties": {
          "type": { "const": "root-cause" },
          "status": { "const": "complete" }
        }
      },
      "then": {
        "required": ["rootCause", "alternativeHypotheses", "whyChain", "derivedConclusion"],
        "properties": {
          "rootCause": {
            "type": "object",
            "required": ["symptom", "proximateCause", "mechanismRootCause"],
            "properties": {
              "symptom": { "type": "string", "minLength": 1 },
              "proximateCause": { "type": "string", "minLength": 1 },
              "mechanismRootCause": { "type": "string", "minLength": 1 }
            }
          },
          "alternativeHypotheses": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "whyChain": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "derivedConclusion": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  ]
}
