{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ravo.dev/schemas/ravo-knowledge-record.schema.json",
  "title": "RAVO Curated Knowledge Record",
  "type": "object",
  "required": ["schemaVersion", "id", "kind", "title", "summary", "content", "status", "scope", "applicability", "sourceRefs", "confidence", "revision", "createdAt", "updatedAt"],
  "properties": {
    "schemaVersion": { "type": "string" },
    "id": { "type": "string", "minLength": 1 },
    "kind": { "enum": ["fact", "decision", "lesson", "principle", "boundary", "terminology", "procedure", "warning"] },
    "title": { "type": "string", "minLength": 1 },
    "summary": { "type": "string", "minLength": 1 },
    "content": { "type": "string", "minLength": 1 },
    "status": { "enum": ["candidate", "needs_review", "active", "stale", "superseded", "archived", "rejected"] },
    "scope": { "enum": ["workspace", "user"] },
    "applicability": { "type": "array", "items": { "type": "string" } },
    "nonApplicability": { "type": "array", "items": { "type": "string" } },
    "sourceRefs": { "type": "array", "items": { "type": "string" } },
    "evidenceLevel": { "type": "string" },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "lastVerifiedAt": { "type": "string" },
    "reviewAfter": { "type": "string" },
    "lastUsedAt": { "type": "string" },
    "useCount": { "type": "integer", "minimum": 0 },
    "revision": { "type": "integer", "minimum": 1 },
    "createdAt": { "type": "string" },
    "updatedAt": { "type": "string" }
  },
  "additionalProperties": true
}
