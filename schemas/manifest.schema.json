{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ravo.dev/schemas/manifest.schema.json",
  "title": "RAVO Workspace Manifest",
  "type": "object",
  "required": ["schemaVersion", "modules"],
  "properties": {
    "schemaVersion": {
      "type": "string"
    },
    "workspace": {
      "type": "string"
    },
    "modules": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["enabled", "artifacts"],
        "properties": {
          "enabled": {
            "type": "boolean"
          },
          "artifacts": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "latestArtifact": {
            "type": "string"
          },
          "latestCompleteArtifact": {
            "type": "string"
          },
          "updatedAt": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
