{
  "schemaVersion": "0.3.1",
  "_template": [
    "Copy to ~/.codex/skill-config/ravo-review.json.",
    "Fill provider fields locally only. Do not commit real API keys."
  ],
  "enableReasoningParams": false,
  "rounds": 2,
  "retry": {
    "maxAttempts": 2,
    "baseDelayMs": 1000,
    "maxDelayMs": 8000,
    "retryableStatusCodes": [429, 502, 503, 504]
  },
  "maxTokens": 48000,
  "stream": true,
  "timeoutMs": 900000,
  "firstEventTimeoutMs": 30000,
  "firstContentTimeoutMs": 0,
  "idleTimeoutMs": 60000,
  "providers": [
    {
      "id": "provider-a",
      "label": "Provider A",
      "enabled": false,
      "apiBase": "https://your-review-api.example.com/v1/responses",
      "apiMode": "responses",
      "apiKey": "REPLACE_LOCALLY_NEVER_COMMIT",
      "modelsMode": "manual",
      "models": [
        { "id": "model-a", "enabled": true },
        { "id": "model-b", "enabled": false }
      ]
    }
  ]
}
